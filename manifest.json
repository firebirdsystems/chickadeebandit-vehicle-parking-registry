  "permissions": {
    "default_audience": "everyone",
    "requires_approval": true
  },
  "storage": "db",
  "resource_limits": {
    "max_db_bytes": 52428800
  },
  "nav": { "label": "Parking" },
  "icon": "🚗"
}
